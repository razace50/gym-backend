generator client {
  provider = "prisma-client-js"
  output = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  RECEPTIONIST
  TRAINER
  MEMBER
}

model User {
  id          Int       @id @default(autoincrement())
  fullName    String
  email       String    @unique
  password    String
  phone       String?
  role        Role

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  member       Member?
  trainer      Trainer?
  receptionist Receptionist?
}

model Member {
  id                Int       @id @default(autoincrement())
  userId            Int       @unique

  age               Int?
  gender            String?
  address           String?

  membershipId      Int?
  trainerId         Int?

  joinDate          DateTime @default(now())

  membershipStart   DateTime?
  membershipEnd     DateTime?

  status            String   @default("ACTIVE")

  user              User @relation(fields: [userId], references: [id])

  membership        Membership? @relation(fields: [membershipId], references: [id])

  trainer           Trainer? @relation(fields: [trainerId], references: [id])

  payments          Payment[]
  attendance        Attendance[]
}

model Trainer {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique

  specialization String?

  user           User @relation(fields: [userId], references: [id])

  members        Member[]
}

model Receptionist {
  id         Int    @id @default(autoincrement())
  userId     Int    @unique

  shift      String?

  user       User @relation(fields: [userId], references: [id])
}

model Membership {
  id          Int      @id @default(autoincrement())
  name        String
  duration    Int
  price       Float

  members     Member[]
}

model Payment {
  id          Int       @id @default(autoincrement())

  memberId    Int
  amount      Float
  status      String

  createdAt   DateTime @default(now())

  member       Member @relation(fields: [memberId], references: [id])
}

model Attendance {
  id          Int       @id @default(autoincrement())

  memberId    Int

  checkIn     DateTime @default(now())
  checkOut    DateTime?

  member      Member @relation(fields: [memberId], references: [id])
}