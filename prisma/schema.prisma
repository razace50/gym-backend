generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  RECEPTIONIST
  TRAINER
  MEMBER
}

model User {
  id       Int     @id @default(autoincrement())
  fullName String
  email    String  @unique
  password String
  phone    String?
  role     Role

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member             Member?
  trainer            Trainer?
  receptionist       Receptionist?
  renewedMemberships MembershipRenewal[]

  createdMembers   Member[]      @relation("MemberCreatedBy")
  updatedMembers   Member[]      @relation("MemberUpdatedBy")
  collectedPayments Payment[]     @relation("PaymentCollectedBy")
  activityLogs     ActivityLog[] @relation("ActivityPerformedBy")
}

model Member {
  id     Int @id @default(autoincrement())
  userId Int @unique

  age     Int?
  gender  String?
  address String?

  membershipId Int?
  trainerId    Int?

  joinDate DateTime @default(now())

  membershipStart DateTime?
  membershipEnd   DateTime?

  status String @default("ACTIVE")

  createdById Int?
  updatedById Int?

  user       User        @relation(fields: [userId], references: [id])
  membership Membership? @relation(fields: [membershipId], references: [id])
  trainer    Trainer?    @relation(fields: [trainerId], references: [id])

  createdBy User? @relation("MemberCreatedBy", fields: [createdById], references: [id])
  updatedBy User? @relation("MemberUpdatedBy", fields: [updatedById], references: [id])

  payments         Payment[]
  attendance       Attendance[]
  renewals         MembershipRenewal[]
  WorkoutPlans     WorkoutPlan[]
  progressRecords  ProgressRecord[]

  @@index([createdById])
  @@index([updatedById])
}

model Trainer {
  id     Int @id @default(autoincrement())
  userId Int @unique

  specialization String?

  user User @relation(fields: [userId], references: [id])

  members         Member[]
  WorkoutPlans    WorkoutPlan[]
  progressRecords ProgressRecord[]
}

model Receptionist {
  id     Int @id @default(autoincrement())
  userId Int @unique

  shift String?

  user User @relation(fields: [userId], references: [id])
}

model Membership {
  id       Int    @id @default(autoincrement())
  name     String
  duration Int
  price    Float

  members     Member[]
  oldRenewals MembershipRenewal[] @relation("OldMembershipRenewals")
  newRenewals MembershipRenewal[] @relation("NewMembershipRenewals")
}

model Payment {
  id Int @id @default(autoincrement())

  memberId Int
  amount   Float
  status   String

  collectedById Int?

  createdAt DateTime @default(now())

  member      Member @relation(fields: [memberId], references: [id])
  collectedBy User?  @relation("PaymentCollectedBy", fields: [collectedById], references: [id])

  @@index([memberId])
  @@index([collectedById])
}

model Attendance {
  id Int @id @default(autoincrement())

  memberId Int

  checkIn  DateTime  @default(now())
  checkOut DateTime?

  member Member @relation(fields: [memberId], references: [id])
}

model MembershipRenewal {
  id Int @id @default(autoincrement())

  memberId        Int
  oldMembershipId Int?
  newMembershipId Int

  oldEndDate DateTime?
  newEndDate DateTime

  amount      Float?
  renewedById Int?

  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  oldMembership Membership? @relation("OldMembershipRenewals", fields: [oldMembershipId], references: [id])
  newMembership Membership  @relation("NewMembershipRenewals", fields: [newMembershipId], references: [id])

  renewedBy User? @relation(fields: [renewedById], references: [id])

  @@index([memberId])
  @@index([oldMembershipId])
  @@index([newMembershipId])
  @@index([renewedById])
}

model GymSetting {
  id           Int      @id @default(autoincrement())
  gymName      String
  logoUrl      String?
  logoFile     String?
  phone        String?
  email        String?
  address      String?
  currency     String   @default("Nrs")
  openingHours String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WorkoutPlan {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  exercises   String
  notes       String?
  memberId    Int
  trainerId   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  member  Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainer Trainer? @relation(fields: [trainerId], references: [id])
}

model ProgressRecord {
  id           Int      @id @default(autoincrement())
  memberId     Int
  trainerId    Int?
  weight       Float?
  height       Float?
  chest        Float?
  waist        Float?
  arms         Float?
  notes        String?
  recordedDate DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  member  Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainer Trainer? @relation(fields: [trainerId], references: [id])

  @@index([memberId])
  @@index([trainerId])
}

model Expense {
  id          Int      @id @default(autoincrement())
  title       String
  category    String
  amount      Float
  expenseDate DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id            Int      @id @default(autoincrement())
  action        String
  entityType    String
  entityId      Int?
  description   String
  performedById Int?
  createdAt     DateTime @default(now())

  performedBy User? @relation("ActivityPerformedBy", fields: [performedById], references: [id])

  @@index([performedById])
  @@index([entityType])
  @@index([createdAt])
}
